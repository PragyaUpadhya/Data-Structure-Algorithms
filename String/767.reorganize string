class Solution {
public:
    string reorganizeString(string s) {
        vector<int> freq(26, 0);

        // Count frequency
        for (char c : s) {
            freq[c - 'a']++;
        }

        // Max heap (frequency, character)
        priority_queue<pair<int, char>> pq;
        for (int i = 0; i < 26; i++) {
            if (freq[i] > 0) {
                pq.push({freq[i], char(i + 'a')});
            }
        }

        string result = "";

        while (pq.size() > 1) {
            auto first = pq.top(); pq.pop();
            auto second = pq.top(); pq.pop();

            // Add two most frequent different characters
            result += first.second;
            result += second.second;

            if (--first.first > 0) pq.push(first);
            if (--second.first > 0) pq.push(second);
        }

        // If one character is left
        if (!pq.empty()) {
            if (pq.top().first > 1) return ""; // not possible
            result += pq.top().second;
        }

        return result;
    }
};
