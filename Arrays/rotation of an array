#include<iostream>
using namespace std;
int main(){
    int arr[4]={3,4,1,2};
    int n = 4;
    int count = 0;
    for(int i=0;i<n-1;i++){
    if(arr[i]>arr[i+1])
          count++;
    }
    //to compare last element with the first one
    if(arr[n-1]>arr[0])
    count++;
    if(count<=1)
      cout<<"array is sorted and rotated"<<endl;
    else
      cout<<"array is not sorted not rotated"<<endl;
    return 0;
}
   
